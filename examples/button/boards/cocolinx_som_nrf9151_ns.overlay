/ {
	buttons {
		compatible = "gpio-keys";
		button0: button_0 {
			gpios = <&gpio0 18 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "button0";
			zephyr,code = <INPUT_KEY_0>;
		};
	};
	aliases {
		button0 = &button0;
	};
};
